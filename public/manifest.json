{
    "manifest_version": 3,
    "name": "Instagram PFP Viewer",
    "version": "1.0",
    "description": "Opens Instagram profile pictures in an in-page HD lightbox.",
    "permissions": [
        "activeTab",
        "cookies",
        "downloads"
    ],
    "host_permissions": [
        "*://*.instagram.com/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.instagram.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}
